generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  SUPERADMIN
  ADMIN
  MANAGER
  SALESPERSON
  FINANCE
  VIEWER
}

enum SubscriptionTier {
  FREE
  PRO
  ENTERPRISE
}

enum VehicleStatus {
  AVAILABLE
  RESERVED
  IN_NEGOTIATION
  SOLD
  PENDING_DELIVERY
  DELIVERED
  WHOLESALE
  TRADED_IN
}

enum VehicleCondition {
  NEW
  USED_EXCELLENT
  USED_GOOD
  USED_FAIR
  CERTIFIED_PRE_OWNED
}

enum FuelType {
  GASOLINE
  DIESEL
  HYBRID
  PLUG_IN_HYBRID
  ELECTRIC
  OTHER
}

enum TransmissionType {
  AUTOMATIC
  MANUAL
  CVT
  DUAL_CLUTCH
}

enum DriveTrain {
  FWD
  RWD
  AWD
  FOUR_WD
}

enum SaleDealStage {
  NEW_LEAD
  CONTACTED
  TEST_DRIVE_SCHEDULED
  TEST_DRIVE_DONE
  OFFER_MADE
  FINANCE_AND_INSURANCE
  CONTRACTED
  PENDING_DELIVERY
  DELIVERED
  LOST
}

enum LeadSource {
  WALK_IN
  WEBSITE
  PHONE
  REFERRAL
  CARGURUS
  AUTOTRADER
  FACEBOOK
  CRAIGSLIST
  OTHER
}

enum FinanceType {
  CASH
  DEALER_FINANCE
  BANK_FINANCE
  CREDIT_UNION
  LEASE
}

enum TradeInCondition {
  EXCELLENT
  GOOD
  FAIR
  POOR
}

enum ContractStatus {
  DRAFT
  SIGNED
  FUNDED
  CANCELLED
}

enum ActivityType {
  NOTE
  CALL
  EMAIL
  MEETING
  TEST_DRIVE
  OFFER
  STAGE_CHANGE
  DOCUMENT_UPLOAD
  SYSTEM
}

enum AlertType {
  DEAL_STALE
  VEHICLE_AGING
  FOLLOW_UP_DUE
  FINANCE_EXPIRING
  CUSTOM
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum Currency {
  USD
  CAD
  EUR
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Organization {
  id               String           @id @default(cuid())
  name             String
  logoUrl          String?
  timezone         String           @default("America/Chicago")
  defaultCurrency  Currency         @default(USD)
  subscriptionTier SubscriptionTier @default(FREE)
  stripeCustomerId String?

  // Dealership-specific
  dealerLicenseNumber String?
  dealerAddress       String?
  dealerCity          String?
  dealerState         String?
  dealerZip           String?
  dealerPhone         String?
  dealerWebsite       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  vehicles   Vehicle[]
  customers  Customer[]
  salesDeals SalesDeal[]
  contracts  PurchaseContract[]
  activities Activity[]
  alerts     Alert[]
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  avatarUrl      String?
  title          String?
  role           UserRole @default(SALESPERSON)
  organizationId String
  passwordHash   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salesDeals   SalesDeal[]  @relation("AssignedDeals")
  activities   Activity[]
  alerts       Alert[]
  accounts     Account[]
  sessions     Session[]

  @@index([organizationId])
  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core Dealership Models ───────────────────────────────────────────────────

model Vehicle {
  id             String @id @default(cuid())
  organizationId String
  stockNumber    String @unique
  vin            String @unique

  // Identity
  year          Int
  make          String
  model         String
  trim          String?
  bodyStyle     String?
  exteriorColor String?
  interiorColor String?

  // Specs
  mileage      Int              @default(0)
  fuelType     FuelType         @default(GASOLINE)
  transmission TransmissionType @default(AUTOMATIC)
  drivetrain   DriveTrain       @default(FWD)
  engineSize   String?
  cylinders    Int?
  mpgCity      Int?
  mpgHighway   Int?

  // Financials
  condition     VehicleCondition @default(USED_GOOD)
  costBasis     Decimal          @default(0) @db.Decimal(12, 2)
  askingPrice   Decimal          @default(0) @db.Decimal(12, 2)
  bookValue     Decimal?         @db.Decimal(12, 2)
  floorPlanCost Decimal?         @db.Decimal(12, 2)

  // Status & Lot
  status         VehicleStatus @default(AVAILABLE)
  lotLocation    String?
  daysOnLot      Int           @default(0)
  lotArrivalDate DateTime      @default(now())

  // Source
  acquisitionSource String?
  auctionName       String?
  previousOwners    Int?

  // Media & Details
  description String?  @db.Text
  features    String[]
  imageUrls   String[]
  carfaxUrl   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salesDeals   SalesDeal[]
  tradeIns     TradeIn[]

  @@index([organizationId, status])
  @@index([organizationId, make, model])
  @@index([organizationId, year])
  @@index([vin])
  @@index([stockNumber])
}

model Customer {
  id             String @id @default(cuid())
  organizationId String

  // Identity
  firstName String
  lastName  String
  email     String?
  phone     String?
  altPhone  String?

  // Address
  address String?
  city    String?
  state   String?
  zip     String?

  // Finance profile
  creditTier        String? // Excellent / Good / Fair / Poor / Unknown
  preApproved       Boolean  @default(false)
  preApprovedAmount Decimal? @db.Decimal(12, 2)
  preApprovedLender String?

  // Lead info
  leadSource LeadSource @default(WALK_IN)
  referredBy String?
  notes      String?    @db.Text
  tags       String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salesDeals   SalesDeal[]
  activities   Activity[]
  Alert        Alert[]

  @@index([organizationId])
  @@index([organizationId, lastName, firstName])
  @@index([email])
}

model SalesDeal {
  id             String @id @default(cuid())
  organizationId String
  dealNumber     String @unique
  customerId     String
  vehicleId      String
  assignedUserId String

  // Pipeline
  stage       SaleDealStage @default(NEW_LEAD)
  leadSource  LeadSource    @default(WALK_IN)
  probability Int           @default(10)

  // Pricing
  askingPrice Decimal  @default(0) @db.Decimal(12, 2)
  offerPrice  Decimal? @db.Decimal(12, 2)
  salePrice   Decimal? @db.Decimal(12, 2)
  costBasis   Decimal  @default(0) @db.Decimal(12, 2)

  // Front-end gross (sale price - cost)
  frontEndGross Decimal @default(0) @db.Decimal(12, 2)

  // Back-end gross (F&I products)
  financeReserve   Decimal? @db.Decimal(12, 2)
  gapInsurance     Decimal? @db.Decimal(12, 2)
  extendedWarranty Decimal? @db.Decimal(12, 2)
  paintProtection  Decimal? @db.Decimal(12, 2)
  otherFiProducts  Decimal? @db.Decimal(12, 2)
  backEndGross     Decimal  @default(0) @db.Decimal(12, 2)

  // Total gross
  totalGross Decimal @default(0) @db.Decimal(12, 2)

  // Finance
  financeType    FinanceType @default(CASH)
  lender         String?
  loanAmount     Decimal?    @db.Decimal(12, 2)
  interestRate   Decimal?    @db.Decimal(6, 4)
  loanTermMonths Int?
  monthlyPayment Decimal?    @db.Decimal(10, 2)
  downPayment    Decimal?    @db.Decimal(12, 2)

  // Trade-in
  hasTradeIn Boolean @default(false)

  // Fees
  docFee          Decimal? @db.Decimal(10, 2)
  titleFee        Decimal? @db.Decimal(10, 2)
  registrationFee Decimal? @db.Decimal(10, 2)
  salesTax        Decimal? @db.Decimal(10, 2)

  // Notes
  internalNotes String?  @db.Text
  tags          String[]

  // Dates
  testDriveAt  DateTime?
  offerMadeAt  DateTime?
  contractedAt DateTime?
  deliveredAt  DateTime?
  closedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer          @relation(fields: [customerId], references: [id])
  vehicle      Vehicle           @relation(fields: [vehicleId], references: [id])
  assignedUser User              @relation("AssignedDeals", fields: [assignedUserId], references: [id])
  contract     PurchaseContract?
  tradeIn      TradeIn?
  activities   Activity[]
  alerts       Alert[]

  @@index([organizationId, stage])
  @@index([organizationId, customerId])
  @@index([organizationId, vehicleId])
  @@index([dealNumber])
  @@index([createdAt])
}

model TradeIn {
  id          String  @id @default(cuid())
  salesDealId String  @unique
  vehicleId   String? // if the trade-in becomes inventory

  // Identity
  year    Int
  make    String
  model   String
  trim    String?
  vin     String?
  mileage Int     @default(0)
  color   String?

  // Valuation
  condition     TradeInCondition @default(GOOD)
  acv           Decimal          @default(0) @db.Decimal(12, 2) // Actual Cash Value
  allowance     Decimal          @default(0) @db.Decimal(12, 2) // What we give customer
  payoffAmount  Decimal?         @db.Decimal(12, 2) // Lien payoff if any
  payoffLender  String?
  netTradeValue Decimal          @default(0) @db.Decimal(12, 2) // allowance - payoff

  kbbValue Decimal? @db.Decimal(12, 2)
  mmrValue Decimal? @db.Decimal(12, 2)

  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  salesDeal SalesDeal @relation(fields: [salesDealId], references: [id], onDelete: Cascade)
  vehicle   Vehicle?  @relation(fields: [vehicleId], references: [id])

  @@index([salesDealId])
}

model PurchaseContract {
  id             String @id @default(cuid())
  salesDealId    String @unique
  contractNumber String @unique

  status   ContractStatus @default(DRAFT)
  signedAt DateTime?
  fundedAt DateTime?

  // Totals
  vehiclePrice        Decimal  @db.Decimal(12, 2)
  tradeAllowance      Decimal? @db.Decimal(12, 2)
  cashDown            Decimal? @db.Decimal(12, 2)
  totalFiProducts     Decimal? @db.Decimal(12, 2)
  totalFees           Decimal? @db.Decimal(12, 2)
  salesTax            Decimal? @db.Decimal(12, 2)
  totalAmountFinanced Decimal? @db.Decimal(12, 2)
  totalOutOfPocket    Decimal? @db.Decimal(12, 2)

  fileUrl String?
  notes   String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  salesDeal      SalesDeal     @relation(fields: [salesDealId], references: [id], onDelete: Cascade)
  Organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId String?

  @@index([salesDealId])
}

model Activity {
  id             String  @id @default(cuid())
  organizationId String
  salesDealId    String?
  customerId     String?
  userId         String

  type        ActivityType
  title       String
  description String?      @db.Text
  metadata    Json?

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salesDeal    SalesDeal?   @relation(fields: [salesDealId], references: [id])
  customer     Customer?    @relation(fields: [customerId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@index([salesDealId, createdAt])
  @@index([customerId, createdAt])
  @@index([organizationId, createdAt])
}

model Alert {
  id             String        @id @default(cuid())
  organizationId String
  userId         String
  type           AlertType
  title          String
  message        String        @db.Text
  severity       AlertSeverity @default(INFO)

  relatedDealId     String?
  relatedCustomerId String?

  isRead Boolean   @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id])
  relatedDeal     SalesDeal?   @relation(fields: [relatedDealId], references: [id])
  relatedCustomer Customer?    @relation(fields: [relatedCustomerId], references: [id])

  @@index([organizationId, userId, isRead])
  @@index([organizationId, createdAt])
}
